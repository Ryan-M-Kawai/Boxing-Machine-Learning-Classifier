# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python

# ── Virtual environment ─────────────────────────────────
venv/
env/
mediapipe_env/
.venv/

# ── MediaPipe model files (large, third-party, download separately) ──
*.task

# ── Trained model weights (large, regenerated by train.py) ──
*.pt
*.pth
!punch_classifier_best.pt
!stance_classifier_best.pt
!punch_classifier_sideways_best.pt

!label_encoder.pkl
!label_encoder_stance.pkl
!label_encoder_sideways.pkl
# ── Training data (personal recordings, grows unbounded) ──
training_data.json
training_data_formatted.json
stance_data.json

# ── Generated plots / analysis output (regenerated by train.py) ──
*.png
*.jpg

# ── Test images used for debugging pose detection ──
*.png
analysis_output/*
!analysis_output/stance/
!analysis_output/stance/*.png

!analysis_output/punch/
!analysis_output/punch/*.png

!analysis_output/sideways/
!analysis_output/sideways/*.png



