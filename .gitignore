# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python

# ── Virtual environment ─────────────────────────────────
venv/
env/
mediapipe_env/
.venv/

# ── MediaPipe model files (large, third-party, download separately) ──
*.task

