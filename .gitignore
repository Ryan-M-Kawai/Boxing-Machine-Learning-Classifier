*.pt
*.pth
!punch_classifier_best.pt
!label_encoder.pkl
# ── Training data (personal recordings, grows unbounded) ──
training_data.json
training_data_formatted.json

# ── Generated plots / analysis output (regenerated by train.py) ──
*.png
*.jpg
!sample_*.png

# ── Test images used for debugging pose detection ──
Pagliacci.PNG
*.PNG

# ── OS junk ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Jupyter (leftover notebook checkpoints, if any) ──────
.ipynb_checkpoints/

